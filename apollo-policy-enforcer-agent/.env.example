APP_NAME=apollo-policy-enforcer-agent
APP_ENV=demo
APP_BASE_URL=http://127.0.0.1:8040
SERVICE_API_KEY=apollo-dev-key
REQUIRE_API_KEY=true
APP_DATA_DIR=./data
APP_EXPORT_DIR=./exports
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NEON_DATABASE_URL=sqlite:///./data/apollo_policy_enforcer.sqlite3
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.1-8B-Instruct
INTENT_TYPING_TIMEOUT_SECONDS=10
PREDICATE_CACHE_TTL_SECONDS=300
ENABLE_FALLBACK_POLICY_STORE=true
ENABLE_FALLBACK_STATE_STORE=true
ENABLE_FALLBACK_AUDIT_STORE=true
