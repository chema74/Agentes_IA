APP_NAME=change-process-coaching-orchestrator
APP_ENV=demo
APP_BASE_URL=http://127.0.0.1:8060
SERVICE_API_KEY=change-dev-key
REQUIRE_API_KEY=true
APP_DATA_DIR=./data
APP_EXPORT_DIR=./exports
STORAGE_BACKEND=local
CACHE_BACKEND=memory
VECTOR_BACKEND=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NEON_DATABASE_URL=sqlite:///./data/change_process_coaching.sqlite3
VECTOR_DIMENSIONS=8
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=change-process-coaching
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
ENABLE_GEMINI_DEPTH=false
INTAKE_TIMEOUT_SECONDS=15
STORAGE_TIMEOUT_SECONDS=10
STORAGE_RETRY_ATTEMPTS=2
STORAGE_RETRY_DELAY_SECONDS=0.2
ENABLE_RATE_LIMIT=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
