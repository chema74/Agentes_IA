APP_ENV=demo
APP_NAME=contract-obligations-agent
APP_DATA_DIR=./data
APP_EXPORT_DIR=./exports
DB_URL=sqlite:///./data/contract_obligations.sqlite3
VECTORSTORE_BACKEND=chroma
CHROMA_PATH=./data/chroma
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=contract-obligations
POSTGRES_URL=postgresql+psycopg://contract_obligations:contract_obligations@localhost:5432/contract_obligations
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=contract-obligations
OBJECT_STORAGE_PREFIX=analysis
LITELLM_MODEL=groq/llama-3.3-70b-versatile
LITELLM_FALLBACK_MODEL=groq/llama-3.1-8b-instant
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MAX_FILE_MB=25
REDACTION_ENABLED=true
HUMAN_REVIEW_HIGH_RISK=true
