# ── CLAVES API ───────────────────────────────────────────
# Copia este archivo como .env y rellena tus claves reales
# NUNCA subas el archivo .env a GitHub

# Groq (GRATUITO) — https://console.groq.com
# Regístrate, ve a API Keys y crea una clave
GROQ_API_KEY=gsk_...

# Tavily (búsqueda web) — https://app.tavily.com
# Plan gratuito: 1.000 búsquedas/mes
TAVILY_API_KEY=tvly-...
